# Normalize line endings to avoid noisy "modified" states on Windows.
# Default policy: text files use LF in repo and working tree.
* text=auto eol=lf

# Windows script files should keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Common source/docs/config files (explicit for readability).
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.sh text eol=lf

# Binary assets (no line-ending conversion).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.zip binary
*.pdf binary
