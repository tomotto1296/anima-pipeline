#!/usr/bin/env sh
# Auto bump __version__ when Python files are staged.

if command -v python >/dev/null 2>&1; then
  python scripts/bump_version_on_py_change.py
  exit $?
fi

if command -v py >/dev/null 2>&1; then
  py -3 scripts/bump_version_on_py_change.py
  exit $?
fi

echo "[version-bump] Python runtime is required for pre-commit hook." >&2
exit 1
